{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
    // and pnpm install -D @types/node
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
